<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Red Moon Records SLOT</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "Hiragino Sans", "Yu Gothic", sans-serif;
      background: linear-gradient(to bottom, #07111f, #140b18, #1f0f0f);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      overflow-x: hidden;
      padding: 20px;
    }

    .container {
      width: 100%;
      max-width: 420px;
      background: rgba(0,0,0,0.45);
      border: 2px solid rgba(255,255,255,0.15);
      border-radius: 24px;
      padding: 24px;
      backdrop-filter: blur(10px);
      box-shadow: 0 0 30px rgba(255, 80, 80, 0.25);
      text-align: center;
    }

    .title {
      font-size: 2rem;
      font-weight: bold;
      letter-spacing: 2px;
      color: #ffd9d9;
      text-shadow: 0 0 10px rgba(255,100,100,0.6);
      margin-bottom: 8px;
    }

    .subtitle {
      color: #d4baba;
      margin-bottom: 24px;
      font-size: 0.95rem;
    }

    .slot-area {
      display: flex;
      justify-content: center;
      gap: 10px;
      margin-bottom: 24px;
    }

    .slot {
      width: 90px;
      height: 90px;
      background: linear-gradient(to bottom, #fff8f0, #d5d5d5);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.5rem;
      color: #111;
      border: 4px solid #d9b26b;
      box-shadow:
        inset 0 2px 6px rgba(255,255,255,0.7),
        0 0 12px rgba(255,220,120,0.35);
    }

    .spin-btn {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 999px;
      background: linear-gradient(to right, #7c1010, #d13b3b);
      color: white;
      font-size: 1.2rem;
      font-weight: bold;
      cursor: pointer;
      transition: transform 0.15s ease;
      box-shadow: 0 0 18px rgba(255,70,70,0.45);
    }

    .spin-btn:active {
      transform: scale(0.97);
    }

    .result {
      margin-top: 22px;
      min-height: 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.05rem;
      line-height: 1.8;
      color: #ffe8b0;
      padding: 10px;
    }

    .footer {
      margin-top: 18px;
      color: rgba(255,255,255,0.5);
      font-size: 0.8rem;
      letter-spacing: 1px;
    }

    .glow {
      animation: glow 1s infinite alternate;
    }

    @keyframes glow {
      from {
        box-shadow: 0 0 10px rgba(255, 210, 100, 0.4);
      }
      to {
        box-shadow: 0 0 24px rgba(255, 210, 100, 0.9);
      }
    }

    @media (max-width: 420px) {
      .slot {
        width: 78px;
        height: 78px;
        font-size: 2rem;
      }

      .title {
        font-size: 1.6rem;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="title">RED MOON SLOT</div>
    <div class="subtitle">夜更けの運試し</div>

    <div class="slot-area">
      <div class="slot" id="slot1">🌙</div>
      <div class="slot" id="slot2">💿</div>
      <div class="slot" id="slot3">🚢</div>
    </div>

    <button class="spin-btn" onclick="spinSlots()">SPIN</button>

    <div class="result" id="result">
      赤い月を揃えろ。
    </div>

    <div class="footer">
      RED MOON RECORDS
    </div>
  </div>

  <script>
    const symbols = ["🌙", "💿", "🚢", "🌺", "🎙", "🎵"];

    const rewards = {
      "🌙": "🌙 当たり！\n1000円割引クーポン",
      "💿": "💿 当たり！\n未公開デモ音源",
      "🚢": "🚢 当たり！\n限定ジャケット画像",
      "🌺": "🌺 当たり！\n奄美壁紙プレゼント",
      "🎙": "🎙 当たり！\nメンバー限定音源",
      "🎵": "🎵 当たり！\n次回曲先行公開"
    };

    function randomSymbol() {
      return symbols[Math.floor(Math.random() * symbols.length)];
    }

    function spinSlots() {
      const result = document.getElementById("result");
      result.innerHTML = "回転中…";

      let count = 0;

      const interval = setInterval(() => {
        document.getElementById("slot1").textContent = randomSymbol();
        document.getElementById("slot2").textContent = randomSymbol();
        document.getElementById("slot3").textContent = randomSymbol();

        count++;

        if (count > 15) {
          clearInterval(interval);

          const s1 = randomSymbol();
          const s2 = randomSymbol();
          const s3 = randomSymbol();

          document.getElementById("slot1").textContent = s1;
          document.getElementById("slot2").textContent = s2;
          document.getElementById("slot3").textContent = s3;

          if (s1 === s2 && s2 === s3) {
            result.innerHTML = rewards[s1];
            result.classList.add("glow");
          } else {
            result.innerHTML = "また夜更けに逢いましょう。";
            result.classList.remove("glow");
          }
        }
      }, 100);
    }
  </script>
</body>
</html>
